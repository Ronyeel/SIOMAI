{
  "expo": {
    "name": "SIOMAI",
    "slug": "SIOMAI",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/siomai_street_logo.png",
    "scheme": "siomai",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#D00D14",
        "foregroundImage": "./assets/images/siomai_street_logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/siomai_street_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#D00D14",
          "android": {
            "image": "./assets/images/siomai_street_logo.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-navigation-bar",
        {
          "style": "light",
          "backgroundColor": "#D00D14"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
